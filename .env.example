# Schappenplan Lab21 — environment template
# Kopieer naar .env en vul de waardes in. Het .env-bestand wordt NIET in git gezet.

# ── Database (Supabase Postgres) ──────────────────────────────────────────────
# DATABASE_URL: pooler-verbinding (poort 6543) voor applicatie-queries
# DIRECT_URL:   direct (poort 5432) voor migraties / Prisma CLI
# Connection strings in Supabase: Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:<WACHTWOORD>@db.<PROJECT-REF>.supabase.co:6543/postgres"
DIRECT_URL="postgresql://postgres:<WACHTWOORD>@db.<PROJECT-REF>.supabase.co:5432/postgres"

# ── NextAuth (v5) ─────────────────────────────────────────────────────────────
# Genereer een nieuwe secret met: openssl rand -base64 32
NEXTAUTH_SECRET="<RANDOM-32-BYTE-STRING>"
# Voor lokale dev: http://localhost:3003 — productie wordt door Vercel ingevuld
NEXTAUTH_URL="http://localhost:3003"

# ── Vercel Blob ───────────────────────────────────────────────────────────────
# Auto-gegenereerd door Vercel bij installatie van Blob storage.
# Lokaal alleen nodig als je upload/download tegen productie-blob test.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_<TOKEN>"
